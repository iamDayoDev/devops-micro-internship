# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which may contain sensitive data
*.tfvars
*.tfvars.json


# Ignore plan files
*.tfplan

# Ignore lock files
.terraform.lock.hcl

# Ignore backup files
*.backup

